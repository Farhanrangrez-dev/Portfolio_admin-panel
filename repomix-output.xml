      <aside className={`fixed left-0 top-0 h-full w-72 bg-gradient-to-b from-[#facc15] to-[#eab308] z-50 transition-all duration-300 ease-out shadow-2xl ${
        isOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'
