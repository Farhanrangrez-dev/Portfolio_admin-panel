    { to: '/admin/profile', icon: 'ri-user-settings-line', label: 'Profile' },
    { to: '/admin/hero-section', icon: 'ri-layout-top-line', label: 'Hero Section' },
    { to: '/admin/settings', icon: 'ri-settings-3-line', label: 'Settings' }
  ]

  const handleLinkClick = () => {
